  "business_size_filters": {
    "small_business": {
      "employee_range": "1-10",
      "revenue_range": "$0-$1M",
      "years_in_business": "1-5"
    },
    "medium_business": {
      "employee_range": "11-50",
      "revenue_range": "$1M-$10M",
      "years_in_business": "5-15"
    },
    "large_business": {
      "employee_range": "51-200",
      "revenue_range": "$10M-$100M",
      "years_in_business": "10+"
    }
  },
  
  "quality_filters": {
    "high_quality_leads": {
      "min_rating": 4.0,
      "min_reviews": 20,
      "has_website": true,
      "has_phone": true,
      "has_email": true,
      "years_in_business": 2
    },
    "medium_quality_leads": {
      "min_rating": 3.5,
      "min_reviews": 10,
      "has_website": true,
      "has_phone": true,
      "has_email": false,
      "years_in_business": 1
    },
    "all_leads": {
      "min_rating": 0,
      "min_reviews": 0,
      "has_website": false,
      "has_phone": false,
      "has_email": false,
      "years_in_business": 0
    }
  },
  
  "search_operators": {
    "google_maps_operators": {
      "near": "near:[location]",
      "in": "in:[neighborhood]",
      "open_now": "open now",
      "hours": "hours:[day time]",
      "rating": "rating:[number]",
      "price": "price:[1-4]",
      "category": "[category]"
    },
    "instagram_operators": {
      "hashtag": "#[tag]",
      "location": "location:[place]",
      "tagged": "@[username]",
      "recent": "recent",
      "top": "top"
    },
    "tiktok_operators": {
      "hashtag": "#[tag]",
      "sound": "sound:[id]",
      "user": "@[username]",
      "trending": "trending",
      "viral": "viral"
    }
  },
  
  "query_builder": {
    "template": "[industry] [business_type] in [city] [filters]",
    "example_queries": [
      "software companies in San Francisco with rating > 4.0",
      "yoga studios in Austin open now",
      "marketing agencies in Chicago with website",
      "restaurants in Miami with outdoor seating",
      "plumbing services in Denver emergency 24/7"
    ],
    "variable_substitution": {
      "{city}": "Replaced with actual city name",
      "{industry}": "Replaced with industry keyword",
      "{business_type}": "Replaced with business type (company, agency, firm, etc.)",
      "{filters}": "Additional filters (rating, hours, services)"
    }
  }
}
